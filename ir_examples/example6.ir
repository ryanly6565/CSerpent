    goto _L1
func:
    BeginFunc
    Param a
    Param b
    _t1 := a + b
    c := _t1
    i := 0
_L2:
    if !(i < 3) goto _L3
    if !(i == 1) goto _L4
    Print True
    goto _L5
_L4:
_L5:
    i := i + 1
    goto _L2
_L3:
    ret := c
    EndFunc
_L1:
    PushParam 1
    PushParam 2
    FuncCall func
    PopParams 2
    _t2 := ret
    Print _t2
